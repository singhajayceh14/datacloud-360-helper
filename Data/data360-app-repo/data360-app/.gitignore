server/data/settings.local.json
server/data/index.sqlite
server/data/index.sqlite-journal
server/data/index.sqlite-wal
server/data/index.sqlite-shm
server/data/*.sqlite*
server/data/grounding.extra.md

# --- editor / tooling noise ---
*.timestamp-*.mjs
*.log
.DS_Store
.vscode/
.idea/

# NOTE: these ARE committed on purpose (do not add them above):
