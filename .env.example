# ---------------------------------------------------------------------------
# DataCloud 360 Helper — environment template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must NEVER be committed.
# ---------------------------------------------------------------------------

# --- Supabase (Phase 1) -----------------------------------------------------
# From Supabase dashboard → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. All-powerful — keep it secret, server-side only, never in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string for Drizzle (Project Settings → Database → Connection string).
# Use the pooled connection (port 6543) for serverless-style access.
DATABASE_URL=

# --- AI providers (Phase 2) -------------------------------------------------
# Set at least one. The Assistant prefers Claude, falling back to Gemini.
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional model overrides (defaults: claude-opus-4-8 / gemini-2.0-flash)
# CLAUDE_MODEL=
# GEMINI_MODEL=
